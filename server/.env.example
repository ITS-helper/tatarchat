# Локально (docker-compose)
DATABASE_URL=postgres://postgres:password@localhost:5432/tatarchat-db
PORT=3001
NODE_ENV=development

# Обязательно задайте в production (Render). Локально можно не указывать — будет dev-секрет.
# JWT_SECRET=случайная_длинная_строка

# На хостинге подставьте URL от провайдера Postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Опционально: фронт не на *.onrender.com — перечислите origin через запятую
# CLIENT_ORIGIN=https://myapp.pages.dev

# Регистрация с сайта включена по умолчанию. Чтобы закрыть: ALLOW_REGISTRATION=false
# ALLOW_REGISTRATION=false
