# Локально (docker-compose)
DATABASE_URL=postgres://postgres:password@localhost:5432/tatarchat
PORT=3001
NODE_ENV=development

# На хостинге подставьте URL от провайдера Postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Опционально: фронт не на *.onrender.com — перечислите origin через запятую
# CLIENT_ORIGIN=https://myapp.pages.dev
